        "feature:feature_store",
        "short_regress",
    ],
    deps = [
        ":common_utils",
        ":feature_store_streaming_fv_integ_base",
        ":fs_integ_test_base",
        "//snowflake/ml/feature_store:feature_store_lib",
        "//snowflake/ml/utils:connection_params",
        "//tests/integ/snowflake/ml/test_utils:db_manager",
        "//tests/integ/snowflake/ml/test_utils:external_volume_manager",
